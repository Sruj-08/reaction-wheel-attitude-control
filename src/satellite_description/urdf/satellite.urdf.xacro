<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="satellite">

  <!-- ================= WORLD ================= -->

  <link name="world"/>

  <!-- ================= SATELLITE BODY ================= -->

  <link name="base_link">

    <visual>
      <geometry>
        <box size="1 1 1"/>
      </geometry>

      <material name="gray">
        <color rgba="0.7 0.7 0.7 1"/>
      </material>

    </visual>

    <collision>
      <geometry>
        <box size="1 1 1"/>
      </geometry>
    </collision>

    <inertial>

      <origin xyz="0 0 0"/>

      <mass value="70"/>

      <inertia
          ixx="12"
          iyy="12"
          izz="12"
          ixy="0"
          ixz="0"
          iyz="0"/>

    </inertial>

  </link>

  <!-- ================= SATELLITE JOINT ================= -->

  <joint name="satellite_joint" type="revolute">

      <parent link="world"/>
      <child link="base_link"/>

      <origin xyz="0 0 0.5"/>

      <axis xyz="0 0 1"/>

      <limit
          lower="-3.14159"
          upper="3.14159"
          effort="100"
          velocity="5"/>

  </joint>

  <!-- ================= REACTION WHEEL ================= -->

  <link name="reaction_wheel">

      <visual>

          <origin xyz="0.7 0 0"/>

          <geometry>

              <cylinder
                  radius="0.15"
                  length="0.05"/>

          </geometry>

          <material name="black">
              <color rgba="0.1 0.1 0.1 1"/>
          </material>

      </visual>

      <collision>

    	<origin xyz="0.7 0 0"/>

   	 <geometry>
              <cylinder
                  radius="0.15"
                  length="0.05"/>
          </geometry>

      </collision>

      <inertial>

          <mass value="2"/>

          <origin xyz="0 0 0"/>

          <inertia
              ixx="0.01"
              iyy="0.01"
              izz="0.02"
              ixy="0"
              ixz="0"
              iyz="0"/>

      </inertial>

  </link>

  <!-- ================= REACTION WHEEL JOINT ================= -->

  <joint name="wheel_joint" type="continuous">

      <parent link="base_link"/>

      <child link="reaction_wheel"/>

      <origin xyz="0.7 0 0"/>

      <axis xyz="0 0 1"/>

  </joint>
  <ros2_control name="GazeboSystem" type="system">

  <hardware>
    <plugin>gazebo_ros2_control/GazeboSystem</plugin>
  </hardware>

  <joint name="satellite_joint">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="wheel_joint">
    <command_interface name="velocity"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

</ros2_control>

<gazebo>
  <plugin filename="libgazebo_ros2_control.so"
          name="gazebo_ros2_control"/>
</gazebo>

<gazebo>
  <plugin filename="libgazebo_ros2_control.so"
          name="gazebo_ros2_control">

    <parameters>
      $(find satellite_description)/config/controllers.yaml
    </parameters>

  </plugin>
</gazebo>
</robot>
